{
  "name": "arisoutre",
  "version": "3.0.0",
  "description": "Bot de modération discord de l'antre des loutres",
  "homepage": "https://github.com/L-Antre-des-Loutres/Otterbots#readme",
  "bugs": {
    "url": "https://github.com/L-Antre-des-Loutres/Otterbots/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/L-Antre-des-Loutres/Otterbots.git"
  },
  "license": "MIT",
  "author": "Antre des Loutres",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "npm run lint && npm run build && node ./build/app/index.js",
    "build": "tsc",
    "lint": "npx eslint \"src/**/*.ts\"",
    "start": "node ./build/app/index.js",
    "purge-duplicates": "npx ts-node src/app/utils/purgeDuplicates.ts",
    "purge-orphan-stats": "npx ts-node src/app/utils/purgeOrphanStats.ts",
    "purge-empty-stats": "npx ts-node src/app/utils/purgeEmptyStats.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "discord.js": "^14.23.2",
    "dotenv": "^17.2.3",
    "figlet": "^1.9.3",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "pocketbase": "^0.26.9",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.38.0"
  }
}
